{
  "name": "@seba174/ng2-pdf-viewer",
  "version": "21.0.0",
  "description": "Angular 21+ standalone component for rendering PDF",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "build:stats": "ng build --stats-json",
    "watch": "ng build --watch --configuration development",
    "analyze": "esbuild-visualizer --metadata dist/stats.json --filename dist/analysis.html",
    "test": "ng test --watch false",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessCustom",
    "test:w": "ng test",
    "lint": "ng lint",
    "packagr": "ng-packagr -p ng-package.json",
    "docs": "ng build --configuration production,docs && node -e \"require('node:fs').copyFileSync('docs/index.html','docs/404.html')\""
  },
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seba174/ng2-pdf-viewer.git"
  },
  "keywords": [
    "angular",
    "pdf",
    "angular-pdf",
    "angular2-pdf",
    "angular21",
    "ng2",
    "ng2-pdf",
    "pdfjs"
  ],
  "author": "seba174",
  "bugs": {
    "url": "https://github.com/seba174/ng2-pdf-viewer/issues"
  },
  "homepage": "https://github.com/seba174/ng2-pdf-viewer#readme",
  "engines": {
    "node": "^22.12.0 || >=24.0.0"
  },
  "dependencies": {
    "pdfjs-dist": "^5.6.205",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@angular/core": ">=21.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/build": "^21.2.7",
    "@angular/cdk": "^21.2.7",
    "@angular/cli": "~21.2.7",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/compiler-cli": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/language-service": "21.2.9",
    "@angular/material": "^21.2.7",
    "@angular/platform-browser": "^21.2.9",
    "@angular/platform-browser-dynamic": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@eslint/js": "^10.0.1",
    "@types/jasmine": "~6.0.0",
    "@types/node": "^25.6.0",
    "angular-eslint": "21.3.1",
    "esbuild-visualizer": "^0.7.0",
    "eslint": "^10.0.3",
    "jasmine-core": "~6.2.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "ng-packagr": "^21.2.2",
    "rxjs": "~7.8.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2"
  }
}